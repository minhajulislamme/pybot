[Unit]
Description=Binance Futures Trading Bot
After=network.target

[Service]
User=minhajulislam
WorkingDirectory=/home/minhajulislam/binance-futuer-trading-bot
ExecStart=/home/minhajulislam/binance-futuer-trading-bot/venv/bin/python /home/minhajulislam/binance-futuer-trading-bot/trading_bot.py
Restart=always
RestartSec=10s
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=binance-bot
Environment="PYTHONUNBUFFERED=1"

[Install]
WantedBy=multi-user.target